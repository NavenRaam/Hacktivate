# Arovy Backend Environment Variables
# Copy this file to .env and fill in your Razorpay test credentials

# Razorpay Test Credentials
# Get these from https://dashboard.razorpay.com → Settings → API Keys → Test Mode
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET

# Razorpay X Payout Account Number (test)
# Found in Razorpay X dashboard under Accounts
RAZORPAY_ACCOUNT=2323230099999999

# Server port
PORT=3002
