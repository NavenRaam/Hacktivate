# Dependencies
# The trailing slash tells Git to ignore any folder named node_modules 
# anywhere in your entire project, no matter how deep it is.
node_modules/

# Environment variables (Crucial for security!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js specific build files
.next/
out/

# Backend build files (if you compile TypeScript to JS)
dist/
build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db